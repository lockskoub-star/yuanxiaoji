# Railway 环境变量配置
# 在 Railway 项目设置中添加以下环境变量

# ========================================
# 必须配置的环境变量
# ========================================

# 豆包模型配置
COZE_WORKLOAD_IDENTITY_API_KEY=your_api_key_here
COZE_INTEGRATION_MODEL_BASE_URL=your_base_url_here

# ========================================
# 可选配置（Railway 会自动设置）
# ========================================

# API 配置（Railway 会自动设置 PORT）
PORT=8000
HOST=0.0.0.0

# 日志配置
LOG_LEVEL=info

# 消息历史配置
MAX_MESSAGE_HISTORY=20

# ========================================
# 注意事项
# ========================================

# 1. COZE_WORKLOAD_IDENTITY_API_KEY 和 COZE_INTEGRATION_MODEL_BASE_URL
#    是必须的，否则服务无法启动
#
# 2. PORT 变量会被 Railway 自动设置为 8000，无需手动设置
#
# 3. 不要在代码中硬编码密钥，始终使用环境变量
#
# 4. 部署后可以在 Railway 控制台的 Variables 标签中管理环境变量
